{
	http_port 8081
	auto_https off
	admin off
}

http://ui.visionnorth.mx:8081 {
	reverse_proxy localhost:8080
	encode gzip zstd

	handle /previews/* {
		root * /opt/html-previews
		file_server
	}
}

http://d.visionnorth.mx:8081 {
	handle /webhooks/* {
	reverse_proxy localhost:8644 {
			header_up Host localhost
			header_up Origin "http://localhost:8644"
		}
	}

	handle {
		respond "VisionNorth API - Sistema operativo. WebUI: https://webui.visionnorth.mx/" 200
	}

	encode gzip zstd
}
