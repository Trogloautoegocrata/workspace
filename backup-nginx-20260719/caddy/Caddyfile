http://back-bone.dev:8081 {
	root * /home/polaris/workspace/projects/BACKBONE/frontend
	encode gzip zstd

	handle /v1/* {
	reverse_proxy localhost:8005
	}

	handle /privacy {
		rewrite /privacy.html
		file_server
	}
	handle /terms {
		rewrite /terms.html
		file_server
	}

	handle /docs {
		rewrite /docs.html
		file_server
	}

	handle {
	try_files {path} /index.html
		file_server
	}
}

http://www.back-bone.dev:8081 {
	redir https://back-bone.dev{uri} permanent
}

http://api.back-bone.dev:8081 {
	reverse_proxy localhost:8005
	encode gzip zstd
}

http://crm.visionnorth.mx:8081 {
	handle /v1/* {
	reverse_proxy localhost:8005
	}

	handle /brand/* {
		root * /home/polaris/workspace/public
		file_server
	}

	handle /Guia-7-Errores-Pipeline-Inmobiliario-Polaris.pdf {
		root * /home/polaris/workspace/public/downloads
		file_server
	}
	handle /guia {
		redir http://crm.visionnorth.mx:8081/Guia-7-Errores-Pipeline-Inmobiliario-Polaris.pdf permanent
	}

	handle {
		root * /home/polaris/workspace/public
	try_files {path} /polaris-landing-premium.html
		file_server
	}

	encode gzip zstd
	header {
		-Server
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}
}

