server {
    server_name stellar.visionnorth.mx;

    # Static landing page for root
    root /home/polaris/workspace/projects/stellar-echo;
    index index.html;

    # API endpoints → bridge
    location /stellar/ {
        proxy_pass http://localhost:8642;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Default: serve static files
    location / {
        try_files $uri $uri/ =404;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/stellar.visionnorth.mx/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/stellar.visionnorth.mx/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = stellar.visionnorth.mx) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    server_name stellar.visionnorth.mx;
    return 404; # managed by Certbot
}