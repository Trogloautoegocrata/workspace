# Pherkad — Estudio de Diseño Interno (vía Cloudflare One Tunnel)
# Sin Basic Auth — acceso solo por tunnel interno

server {
    listen 80;
    server_name pherkad.polaris.pw;

    location / {
        proxy_pass http://127.0.0.1:7456;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 90s;
        proxy_send_timeout 90s;
    }

    location /_next/static {
        proxy_pass http://127.0.0.1:7456;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /api/health {
        proxy_pass http://127.0.0.1:7456;
        access_log off;
    }

    access_log /var/log/nginx/pherkad.access.log;
    error_log /var/log/nginx/pherkad.error.log;
}